# HD-OPERATIONS Environment Template
# Copy to .env and fill in real values. Never commit .env to version control.

NODE_ENV=development
APP_NAME=HD-OPERATIONS
PORT=3005
APP_PORT=3005
API_BASE_URL=http://localhost:3005

# HD-CORE dependency resolution (local | registry)
HD_CORE_MODE=local

# Databases
DATABASE_URL=postgresql://user:password@localhost:5432/hdoperations
AUDIT_DB_URL=postgresql://user:password@localhost:5432/hdaudit

# Event Bus
EVENT_BUS_URL=amqp://localhost:5672

# Authentication
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRY=1h
# Dev-only admin password fallback (never use in production)
DEV_ADMIN_PASSWORD=admin123

# n8n Automation
N8N_WEBHOOK_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=dev-n8n-secret

# Cross-platform event bus (ingest endpoint secured by this shared secret)
EVENT_BUS_SECRET=replace-with-a-strong-secret

# Logging
LOG_LEVEL=info
